{
  "name": "yandisk",
  "version": "1.1.1",
  "description": "yandisk: A lightweight Node.js library for interacting with the Yandex Disk REST API. Perform file uploads, downloads, manage directories, and more with a simple, promise‑based interface.",
  "repository": {
    "type": "git",
    "url": "https://github.com/Simfort/yandisk"
  },
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "build": "npx tsc",
    "test": "vitest"
  },
  "keywords": [
    "yandex",
    "yandex-disk",
    "library",
    "typescript",
    "api",
    "rest"
  ],
  "files": [
    "dist"
  ],
  "author": "lemondzavadavid265@gmail.com",
  "license": "MIT",
  "type": "module",
  "devDependencies": {
    "@types/node": "^25.6.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.5"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  }
}
