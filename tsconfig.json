{
  "compilerOptions": {
    "outDir": "dist",
    "module": "nodenext",
    "target": "es2023",
    "jsx": "react",
    "rootDir": "src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "types": ["node"]
  },
  "include": ["src"],
  "exclude": ["node_modules", "build"]
}
